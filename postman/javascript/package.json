{
  "name": "gatling-ecomm-postman-js",
  "version": "1.0.0-SNAPSHOT",
  "private": true,
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "3.15.103",
    "@gatling.io/http": "3.15.103",
    "@gatling.io/postman": "3.15.103"
  },
  "devDependencies": {
    "@gatling.io/cli": "3.15.103",
    "prettier": "3.9.4",
    "rimraf": "6.1.3"
  },
  "scripts": {
    "clean": "rimraf target",
    "format": "prettier --write \"**/*.js\"",
    "build": "gatling build",
    "basicSimulation": "gatling run --simulation basicSimulation",
    "advancedSimulation": "gatling run --simulation advancedSimulation"
  }
}
